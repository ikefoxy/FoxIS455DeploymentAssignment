@page
@model ShopWeb.Pages.Admin.OrdersModel
@{
    ViewData["Title"] = "Order history";
}

<div class="app-shell mb-4">
    <p class="page-eyebrow mb-0">Administration</p>
    <h1 class="page-title h3 mb-2">Order history</h1>
    <p class="text-muted mb-0">Recent orders (up to 500). Amounts are shown in USD.</p>
</div>

<div class="table-responsive app-shell p-0 overflow-hidden">
    <table class="table table-sm table-hover table-professional mb-0">
        <thead class="table-light">
            <tr>
                <th scope="col">Order</th>
                <th scope="col">Placed</th>
                <th scope="col">Customer</th>
                <th scope="col" class="text-end">Total</th>
                <th scope="col" class="text-end">Risk</th>
                <th scope="col">Fraud label</th>
                <th scope="col">Payment</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var o in Model.Orders)
        {
            <tr>
                <td class="font-monospace text-secondary">#@o.OrderId</td>
                <td class="text-nowrap">@o.OrderDateTime</td>
                <td>@o.CustomerName</td>
                <td class="text-end">@o.OrderTotal.ToString("C2")</td>
                <td class="text-end">@o.RiskScore.ToString("F1")</td>
                <td>
                    @if (o.IsFraud)
                    {
                        <span class="badge rounded-pill text-bg-danger">Yes</span>
                    }
                    else
                    {
                        <span class="badge rounded-pill text-bg-success">No</span>
                    }
                </td>
                <td>@OrderDisplay.PaymentMethodLabel(o.PaymentMethod)</td>
            </tr>
        }
        </tbody>
    </table>
</div>
